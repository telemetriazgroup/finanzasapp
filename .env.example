# ────────────────────────────────────────────────
#  FinanzasApp — Variables de entorno
#  Copiar a .env y completar valores reales
#  NUNCA commitear .env al repositorio
# ────────────────────────────────────────────────

# ── App ──────────────────────────────────────────
APP_NAME=FinanzasApp
NODE_ENV=production
APP_URL=http://161.132.53.51

# ── API ──────────────────────────────────────────
PORT=4000
API_PREFIX=/api/v1

# ── JWT ──────────────────────────────────────────
JWT_SECRET=Yonacieniquitosen1994barriobelen
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=otro_string_diferente_largo_para_refresh_token
JWT_REFRESH_EXPIRES_IN=7d

# ── Base de datos (PostgreSQL) ───────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=finanzasapp_db
DB_USER=finanzas_user
DB_PASSWORD=Lpmp2018!
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Redis ────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=cambia_esto_por_password_redis
REDIS_TTL=900                   # Segundos — 15 min para sesiones

# ── MinIO (almacenamiento de archivos) ───────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=cambia_esto_por_password_minio
MINIO_BUCKET_RECEIPTS=recibos   # Bucket para comprobantes de transacciones

# ── Frontend (React) ─────────────────────────────
VITE_API_URL=http://161.132.53.51/api/v1
VITE_APP_NAME=FinanzasApp

# ── Email (notificaciones) ────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=tu_api_key_sendgrid
EMAIL_FROM=no-reply@tudominio.com

# ── Moneda por defecto ───────────────────────────
DEFAULT_CURRENCY=PEN             # Soles peruanos (cambiar según país)
DEFAULT_TIMEZONE=America/Lima

# ── Rate limiting ────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000     # 15 minutos
RATE_LIMIT_MAX_REQUESTS=100

# ── Logs ─────────────────────────────────────────
LOG_LEVEL=info                   # error | warn | info | debug
LOG_FORMAT=json                  # json | pretty

# ── Certbot / SSL ─────────────────────────────────
CERTBOT_EMAIL=tu@email.com
DOMAIN=161.132.53.51
